for box in refined_boxes[:4]:
    rect = patches.Rectangle((box[0].item(), box[1].item()), (box[2]-box[0]).item(), (box[3]-box[1]).item(),
                             linewidth=1, edgecolor='blue', facecolor='none') # Blue for refined
    axes[3].add_patch(rect)
axes[3].set_title("4. Refined Proposals (Before NMS)")
axes[3].axis('off')


# 5. Final Detections (After NMS)
axes[4].imshow(img_resized_for_display)
for box, score in zip(final_boxes, final_scores):
    score_item = score.item() if torch.is_tensor(score) else score
    # Convert tensor coordinates to Python floats using .item()
    rect = patches.Rectangle((box[0].item(), box[1].item()), (box[2]-box[0]).item(), (box[3]-box[1]).item(),
                             linewidth=2, edgecolor='g', facecolor='none')
    axes[4].add_patch(rect) # Adjusted index
    axes[4].text(box[0].item(), box[1].item()-5, f"{score_item:.2f}", color='white', fontsize=12, bbox=dict(facecolor='green', alpha=0.5))
