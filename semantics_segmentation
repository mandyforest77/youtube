# Custom Dataset for a single image with a manually provided mask
class SingleImageSegmentationDataset(Dataset):
    def __init__(self, image_path, mask_file_path, image_size=(5, 5)): # User requested 5x5
        self.image_path = image_path
        self.mask_file_path = mask_file_path
        self.image_size = image_size

        # Load the original image
        self.image = Image.open(image_path).convert("RGB")

        # Load the manually labeled mask and convert to grayscale
        mask_image_pil = Image.open(mask_file_path).convert("L")
        mask_image_resized = mask_image_pil.resize(image_size, Image.NEAREST)
        mask_np = np.array(mask_image_resized)

        # Remap unique non-zero values to 1, 2, ... for a fixed number of classes
        unique_labels = np.unique(mask_np[mask_np > 0]) # Get unique non-zero labels
        label_mapping = {old_label: new_label + 1 for new_label, old_label in enumerate(unique_labels)}

        # Apply mapping: 0 remains 0, other unique labels get sequential IDs starting from 1
        remapped_mask_np = np.zeros_like(mask_np)
        for old_label, new_label in label_mapping.items():
            remapped_mask_np[mask_np == old_label] = new_label

        mask_np = remapped_mask_np

        # Set num_classes based on the remapped unique labels + 1 for background
        # If there are N unique non-zero labels, num_classes will be N+1 (0 for background)
        self.num_classes = len(unique_labels) + 1
        # If no non-zero labels, num_classes is 1 (only background)
        if self.num_classes == 0: self.num_classes = 1

        # Ensure mask is a tensor with appropriate type (long for CrossEntropyLoss)
        self.generated_mask = torch.from_numpy(mask_np.astype(np.long))

        # Define transformations for the image
        self.transform = transforms.Compose([
            transforms.Resize(image_size),
            transforms.ToTensor(),
        ])

    def __len__(self):
        return 1 # This dataset contains only one image

    def __getitem__(self, idx):
        # Transform the image
        transformed_image = self.transform(self.image)
        # Return the transformed image and the loaded mask
        return transformed_image, self.generated_mask

# 2. 모델 준비 및 이미지 로드
device = torch.device("cuda" if torch.cuda.is_available() else "cpu")

# Create custom dataset first to determine the actual number of classes
single_image_dataset = SingleImageSegmentationDataset(
    image_path=image_path,
    mask_file_path=mask_path, # Pass the path to the manually labeled mask
    image_size=(5, 5) # User requested 5x5
)

# Initialize the model with the dynamically determined num_classes from the dataset
model = SimpleSegNet(num_classes=single_image_dataset.num_classes).to(device).train() # Set to train mode initially

# For training, we use a batch size. If batch_size > 1, the single image will be repeated.
batch_size = 1 # You can adjust this. The single image will be sampled repeatedly.

single_image_dataloader = DataLoader(single_image_dataset, batch_size=batch_size, shuffle=True)
# print(single_image_dataloader)
num_epochs = 500 # Revert to 500 epochs for better training
optimizer = torch.optim.Adam(model.parameters(), lr=0.001)
criterion = nn.CrossEntropyLoss()


model.train()
for epoch in range(num_epochs):
    model.train() # Set model to training mode
    running_loss = 0.0
    for i, (inputs, labels) in enumerate(single_image_dataloader):
        inputs = inputs.to(device)
        labels = labels.to(device)
        if epoch ==498:
          print(labels)

        # Zero the parameter gradients
        optimizer.zero_grad()

        # Forward pass
        outputs = model(inputs)
        # if epoch == 498:
        #   print("a", outputs)
        # Calculate loss
        loss = criterion(outputs, labels)
        # if epoch == 498:
        #   print("a", len(single_image_dataset))
        # Backward pass and optimize
        loss.backward()
        optimizer.step()

        running_loss += loss.item() * inputs.size(0)

    # Note: len(single_image_dataset) will be 1, so this epoch loss might be misleading
    # as it's calculating loss over a dataset with only one unique item (repeatedly sampled).
    epoch_loss = running_loss / len(single_image_dataset)
    if epoch % 10 == 0:
      print(f'Epoch [{epoch+1}/{num_epochs}], Loss: {epoch_loss:.4f}')

