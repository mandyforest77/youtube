# 1. 초간단 세그멘테이션 모델 정의 (Encoder-Decoder 구조)
class SimpleSegNet(nn.Module):
    def __init__(self, num_classes):
        super(SimpleSegNet, self).__init__()
        # 특징 추출 (Downsampling)
        self.enc1 = nn.Conv2d(3, 4, kernel_size=3, padding=1)
        self.enc2 = nn.Conv2d(4, 5, kernel_size=3, padding=1)
        self.pool = nn.MaxPool2d(2, 2)

        # 복원 (Upsampling)
        self.dec1 = nn.Conv2d(5, 4, kernel_size=3, padding=1)
        self.dec2 = nn.Conv2d(4, num_classes, kernel_size=3, padding=1)
        # Removed self.upsample as F.interpolate will be used directly

    def forward(self, x):
        initial_h, initial_w = x.shape[2:] # Get the original input spatial dimensions (e.g., 5x5)

        x = F.relu(self.enc1(x))
        # if epoch==498: # Print before pooling
        #   print("t", x)
        x = self.pool(x)
        # if epoch==498: # Print before pooling
        #   print("t", x)

        x = F.relu(self.enc2(x))
        # if epoch==498: # Print before pooling
        #     print("t", x)
        x = self.pool(x) # For a 5x5 input, this will result in a 1x1 spatial dimension
        # if epoch==498: # Print after pooling
        #     print("t:", x)
        # Upsample to an intermediate size. For a 1x1 feature map, upsample to 2x2 first.
        x = F.interpolate(x, size=(2, 2), mode='bilinear', align_corners=True)
        # if epoch == 498:
        #   print(x)
        x = F.relu(self.dec1(x))

        # Upsample to the final target output size (initial_h, initial_w) which is 5x5
        x = F.interpolate(x, size=(initial_h, initial_w), mode='bilinear', align_corners=True)

        x = self.dec2(x)
        # if epoch == 498:
        #   print(x)
        return x

